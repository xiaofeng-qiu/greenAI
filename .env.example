DATABASE_URL="postgresql://greenai:greenai@localhost:5432/greenai"
POSTGRES_PASSWORD="your-strong-password"

JWT_SECRET="change-me-min-32-chars-please-use-random"
API_PUBLISH_PORT=3000
PORT=3000

# Vitest：若已配置 DATABASE_URL + JWT_SECRET，默认会跑 `src/integration/*.integration.test.ts`（需 Postgres 已 migrate）。
# 无数据库或只想跑单元测试：SKIP_INTEGRATION_TESTS=1。
# DATABASE_URL 主机名为 `db`（Compose 内网）且在宿主机跑测试时会自动跳过集成测试；要在宿主机跑通请改为 localhost 或设 RUN_INTEGRATION_TESTS=1。
# SKIP_INTEGRATION_TESTS=1
WECHAT_APPID="your-mini-program-appid"
WECHAT_SECRET="your-mini-program-secret"
CRON_HMAC_SECRET="change-me-cron-shared-secret"
SUBSCRIBE_TEMPLATE_ID="your-approved-template-id"

# --- Optional: 百度 AI 植物识别（小程序「拍照识别」；两者都填才启用）---
# BAIDU_API_KEY=""
# BAIDU_SECRET_KEY=""

# --- Optional: 视觉大模型植物诊断（OpenAI 兼容 chat/completions + 图；需 API Key）---
# DIAGNOSE_LLM_API_KEY=""
# DIAGNOSE_LLM_BASE_URL="https://api.openai.com/v1"
# DIAGNOSE_LLM_MODEL="gpt-4o-mini"
# 同一套 Key 亦用于盆土拍照估干湿（POST /soil/estimate-photo）；可选传 plantId 以写入土壤记录表。

# --- Admin 运维控制台（admin/ 独立服务；与主 API 共用 DATABASE_URL）---
# ADMIN_API_TOKEN="change-me-long-random-admin-token"
# ADMIN_PORT=3100
# 可选：宿主机应用日志路径，供管理台「系统日志」页尾部展示
# ADMIN_SYSTEM_LOG_PATH="/var/log/greenai-api.log"

# --- 计划书对齐说明（代码侧已实现，非密钥）---
# - 用户：空调偏干、窗台朝向参与浇水间隔；天气快照 30min 内存缓存。
# - 植物：科属/难度/浇水量(ml)/肥料类型/注意事项；连续跳过浇水会略拉长间隔。
# - 盆土：LLM 返回湿度 + 肥力粗分；带 plantId 时写入 SoilRecord 供提醒任务参考。
# - 订阅提醒：预报偏湿时推迟浇水提醒；近 36h 盆土偏湿时推迟浇水提醒。

