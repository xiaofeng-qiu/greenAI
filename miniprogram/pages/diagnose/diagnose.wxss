.diagnose-hero {
  margin-bottom: var(--ga-space-lg);
}

.diagnose-expert {
  padding: 28rpx 28rpx 32rpx;
  margin-bottom: var(--ga-space-lg);
}

.diagnose-expert__title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--ga-text);
  margin-bottom: 10rpx;
}

.diagnose-expert__body {
  display: block;
  font-size: 26rpx;
  line-height: 1.55;
  color: var(--ga-text-secondary);
  margin-bottom: 20rpx;
}

.diagnose-contact-btn {
  margin: 0 0 16rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 999rpx;
  background: var(--ga-brand);
  color: #f6fffa;
  border: none;
}

.diagnose-expert__note {
  display: block;
  font-size: 22rpx;
  color: var(--ga-text-muted);
  line-height: 1.45;
}

.diagnose-panel {
  padding: 28rpx 28rpx 32rpx;
  margin-bottom: var(--ga-space-lg);
}

.diagnose-panel__title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--ga-text);
  margin-bottom: 8rpx;
}

.diagnose-panel__hint {
  display: block;
  font-size: 24rpx;
  color: var(--ga-text-muted);
  margin-bottom: 20rpx;
  line-height: 1.45;
}

.diagnose-row-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.diagnose-btn {
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.diagnose-btn--primary {
  background: var(--ga-brand);
  color: #f4faf6;
}

.diagnose-btn--ghost {
  border: 1rpx solid var(--ga-border-strong);
  color: var(--ga-brand);
  background: var(--ga-bg-elevated);
}

.diagnose-btn--disabled {
  opacity: 0.45;
  pointer-events: none;
}

.diagnose-field {
  margin-bottom: 8rpx;
}

.diagnose-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: var(--ga-text-muted);
  text-transform: uppercase;
  margin-bottom: 14rpx;
}

.diagnose-label--spaced {
  margin-top: 24rpx;
}

.diagnose-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 22rpx;
  font-size: 28rpx;
  color: var(--ga-text);
  background: var(--ga-bg-elevated);
  border-radius: var(--ga-radius-sm);
  border: 1rpx solid var(--ga-border-strong);
}

.diagnose-picker {
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: var(--ga-text);
  background: var(--ga-bg-elevated);
  border-radius: var(--ga-radius-sm);
  border: 1rpx solid var(--ga-border-strong);
}

.diagnose-muted {
  padding: 28rpx;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  line-height: 1.55;
  margin-bottom: var(--ga-space-lg);
}

.diagnose-llm-result {
  padding: 28rpx 28rpx 32rpx;
  margin-bottom: var(--ga-space-lg);
  background: linear-gradient(145deg, #fff9ef, #fffdf8);
  border: 1rpx solid rgba(184, 134, 11, 0.25);
}

.diagnose-llm-result__title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #7a5210;
  margin-bottom: 16rpx;
}

.diagnose-summary {
  display: block;
  font-size: 28rpx;
  color: var(--ga-text-secondary);
  line-height: 1.55;
  margin-bottom: 20rpx;
}

.diagnose-issue {
  margin-bottom: 20rpx;
}

.diagnose-issue__title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ga-text);
  margin-bottom: 8rpx;
}

.diagnose-issue__detail {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  line-height: 1.5;
}

.diagnose-action-line {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  line-height: 1.55;
  padding-left: 4rpx;
  margin-bottom: 6rpx;
}

.diagnose-tip {
  font-size: 26rpx;
  color: var(--ga-info);
  background: var(--ga-info-soft);
  padding: 18rpx 20rpx;
  border-radius: var(--ga-radius-sm);
  line-height: 1.5;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(47, 82, 128, 0.12);
}

.diagnose-tip--top {
  margin-top: 20rpx;
}

.diagnose-disclaimer {
  display: block;
  font-size: 22rpx;
  color: var(--ga-text-muted);
  line-height: 1.5;
}

.diagnose-disclaimer--top {
  margin-top: 20rpx;
}

.diagnose-group-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: var(--ga-brand);
  margin: 28rpx 0 12rpx;
  letter-spacing: 0.04em;
}

.diagnose-symptom {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--ga-border);
}

.diagnose-symptom checkbox {
  margin-top: 4rpx;
}

.diagnose-symptom__text {
  flex: 1;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: var(--ga-text);
  line-height: 1.45;
}

.diagnose-submit {
  margin-top: 32rpx;
  text-align: center;
  padding: 26rpx 24rpx;
  border-radius: var(--ga-radius-md);
  font-size: 30rpx;
  font-weight: 700;
  color: #f4faf6;
  background: linear-gradient(135deg, var(--ga-brand), var(--ga-brand-mid));
}

.diagnose-submit--disabled {
  opacity: 0.45;
  pointer-events: none;
}

.diagnose-result {
  margin-top: 16rpx;
  padding-bottom: 48rpx;
}

.diagnose-cause {
  padding: 28rpx;
  margin-bottom: var(--ga-space);
  border-left: 6rpx solid var(--ga-brand-mid);
}

.diagnose-cause__title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--ga-text);
  margin-bottom: 12rpx;
}

.diagnose-cause__summary {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  line-height: 1.55;
  margin-bottom: 16rpx;
}

.diagnose-kb {
  padding: 24rpx 28rpx 28rpx;
  margin-bottom: var(--ga-space-lg);
}

.diagnose-kb__title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--ga-text);
  margin-bottom: 16rpx;
}

.diagnose-kb__row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--ga-border);
}

.diagnose-kb__row:last-child {
  border-bottom: none;
}

.diagnose-kb__row-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ga-brand);
}

.diagnose-kb__row-sum {
  display: block;
  font-size: 24rpx;
  color: var(--ga-text-secondary);
  line-height: 1.45;
  margin-top: 8rpx;
}
