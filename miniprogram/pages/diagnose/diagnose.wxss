.page {
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 48rpx;
}

.intro {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 12rpx;
}

.picker-value {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2e7d32;
  margin: 20rpx 0 12rpx;
}

.symptom-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.symptom-row checkbox {
  margin-top: 4rpx;
}

.symptom-text {
  flex: 1;
  margin-left: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
}

.submit {
  margin-top: 32rpx;
}

.result {
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #e0e0e0;
}

.cause-card {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #2e7d32;
}

.cause-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 12rpx;
}

.cause-summary {
  font-size: 26rpx;
  color: #555;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.action-item {
  font-size: 26rpx;
  color: #444;
  line-height: 1.5;
  padding-left: 8rpx;
  margin-bottom: 8rpx;
}

.context-tip {
  font-size: 26rpx;
  color: #1565c0;
  background: #e3f2fd;
  padding: 16rpx;
  border-radius: 10rpx;
  margin-bottom: 16rpx;
  line-height: 1.45;
}

.disclaimer {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
  margin-top: 16rpx;
}
