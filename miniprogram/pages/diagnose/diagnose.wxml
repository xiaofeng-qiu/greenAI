<view class="ga-page diagnose">
  <view class="ga-hero diagnose-hero">
    <text class="ga-hero__eyebrow">辅助工具</text>
    <view class="ga-hero__title">问题诊断</view>
    <view class="ga-hero__desc">可先勾选症状做规则参考，或使用「拍照 AI 诊断」（需服务端配置）。结果仅供参考。</view>
  </view>

  <view wx:if="{{llmDiagnoseEnabled}}" class="diagnose-panel ga-card">
    <text class="diagnose-panel__title">拍照 AI 诊断</text>
    <text class="diagnose-panel__hint">{{llmImageLabel}}</text>
    <view class="diagnose-row-btns">
      <view class="diagnose-btn diagnose-btn--primary" bindtap="onPickImage">选择 / 拍摄照片</view>
      <view class="diagnose-btn diagnose-btn--ghost {{!llmImageBase64 ? 'diagnose-btn--disabled' : ''}}" bindtap="onSubmitLlm">提交分析</view>
    </view>
    <view class="diagnose-field">
      <text class="diagnose-label">文字补充（可选）</text>
      <textarea
        class="diagnose-textarea"
        placeholder="例如：最近两周浇水频率、是否施肥、是否换盆等"
        value="{{userNote}}"
        maxlength="800"
        bindinput="onUserNoteInput"
      />
    </view>
  </view>
  <view wx:else class="diagnose-muted ga-card">当前未启用视觉大模型诊断（服务器未配置 DIAGNOSE_LLM_API_KEY）。仍可使用下方规则诊断。</view>

  <view wx:if="{{llmResult && llmResult.diagnosis}}" class="diagnose-llm-result ga-card">
    <text class="diagnose-llm-result__title">AI 参考结论</text>
    <text class="diagnose-summary">{{llmResult.diagnosis.summary}}</text>
    <block wx:for="{{llmResult.diagnosis.likely_issues}}" wx:for-item="iss" wx:for-index="ix" wx:key="ix">
      <view class="diagnose-issue">
        <text class="diagnose-issue__title">{{iss.title}}</text>
        <text class="diagnose-issue__detail">{{iss.detail}}</text>
      </view>
    </block>
    <text class="diagnose-label diagnose-label--spaced">建议措施</text>
    <block wx:for="{{llmResult.diagnosis.immediate_actions}}" wx:key="*this">
      <text class="diagnose-action-line">· {{item}}</text>
    </block>
    <text wx:if="{{llmResult.diagnosis.caution}}" class="diagnose-tip diagnose-tip--top">{{llmResult.diagnosis.caution}}</text>
    <text wx:if="{{llmResult.diagnosis.needs_expert_visit}}" class="diagnose-tip">建议尽快携带样本或照片咨询线下园艺 / 植保人员。</text>
    <text class="diagnose-disclaimer diagnose-disclaimer--top">{{llmResult.disclaimer}}</text>
  </view>

  <view class="ga-section-title">规则诊断</view>
  <view class="diagnose-panel ga-card">
    <view class="diagnose-field">
      <text class="diagnose-label">关联植物（可选）</text>
      <picker mode="selector" range="{{plantLabels}}" value="{{plantPickerIndex}}" bindchange="onPlantPickerChange">
        <view class="diagnose-picker">{{plantLabels[plantPickerIndex]}}</view>
      </picker>
    </view>

    <checkbox-group bindchange="onSymptomChange">
      <block wx:for="{{symptomGroups}}" wx:key="group">
        <text class="diagnose-group-title">{{item.group}}</text>
        <label wx:for="{{item.items}}" wx:for-item="sym" wx:key="id" class="diagnose-symptom">
          <checkbox value="{{sym.id}}" checked="{{sym.checked}}" color="#2a4d3a" />
          <text class="diagnose-symptom__text">{{sym.label}}</text>
        </label>
      </block>
    </checkbox-group>

    <view class="diagnose-submit {{submitDisabled ? 'diagnose-submit--disabled' : ''}}" bindtap="onSubmit">生成参考意见</view>
  </view>

  <view wx:if="{{result}}" class="diagnose-result">
    <view class="ga-section-title">参考意见</view>
    <block wx:for="{{result.causes}}" wx:key="id">
      <view class="diagnose-cause ga-card">
        <text class="diagnose-cause__title">{{item.title}}</text>
        <text class="diagnose-cause__summary">{{item.summary}}</text>
        <block wx:for="{{item.actions}}" wx:for-item="act" wx:key="*this">
          <text class="diagnose-action-line">· {{act}}</text>
        </block>
      </view>
    </block>
    <block wx:for="{{result.contextTips}}" wx:key="*this">
      <view class="diagnose-tip">{{item}}</view>
    </block>
    <text class="diagnose-disclaimer">{{result.disclaimer}}</text>
  </view>
</view>
