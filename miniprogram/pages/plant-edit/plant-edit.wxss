.plant-identify {
  padding: 32rpx 28rpx 36rpx;
  margin-bottom: var(--ga-space-lg);
  border: 1rpx solid rgba(42, 77, 58, 0.12);
  background: linear-gradient(165deg, #f6faf7 0%, #e8f0eb 100%);
}

.plant-identify-kicker {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--ga-brand-mid);
  text-transform: uppercase;
}

.plant-identify-title {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--ga-text);
  letter-spacing: -0.02em;
}

.plant-identify-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  line-height: 1.55;
}

.plant-identify-stage {
  position: relative;
  height: 200rpx;
  margin: 32rpx 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plant-identify-ring {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx dashed rgba(42, 77, 58, 0.22);
}

.plant-identify-lens {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #ffffff, #c8dccf);
  box-shadow:
    inset 0 -8rpx 24rpx rgba(42, 77, 58, 0.12),
    0 12rpx 32rpx rgba(21, 33, 24, 0.08);
  border: 3rpx solid rgba(255, 255, 255, 0.9);
}

.plant-identify-cta {
  text-align: center;
  padding: 26rpx 24rpx;
  border-radius: var(--ga-radius-md);
  font-size: 30rpx;
  font-weight: 700;
  color: #f4faf6;
  background: linear-gradient(135deg, var(--ga-brand), var(--ga-brand-mid));
  box-shadow: var(--ga-shadow);
}

.plant-identify-photo {
  display: block;
  width: 100%;
  height: 360rpx;
  border-radius: var(--ga-radius-sm);
  margin: 24rpx 0 28rpx;
  object-fit: cover;
  background: var(--ga-bg-elevated);
}

.plant-identify-baike {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--ga-radius-sm);
}

.plant-identify-baike__desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--ga-text-secondary);
  margin-bottom: 16rpx;
}

.plant-identify-baike__link {
  display: inline-flex;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ga-brand);
}

.plant-soil-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--ga-text-muted);
}

.plant-form-hero {
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.plant-block {
  padding: 8rpx 8rpx 12rpx;
  margin-bottom: var(--ga-space);
}

.plant-field {
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid var(--ga-border);
}

.plant-field:last-child {
  border-bottom: none;
}

.plant-field--row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.plant-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--ga-text-muted);
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.plant-field--row .plant-label {
  margin-bottom: 0;
}

.plant-label--inline {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ga-text);
  letter-spacing: 0;
  text-transform: none;
}

.plant-input {
  width: 100%;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.2;
  height: 74rpx;
  color: var(--ga-text);
  background: var(--ga-bg-elevated);
  border-radius: var(--ga-radius-sm);
  border: 1rpx solid var(--ga-border-strong);
  box-sizing: border-box;
}

.plant-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--ga-text);
  background: var(--ga-bg-elevated);
  border-radius: var(--ga-radius-sm);
  border: 1rpx solid var(--ga-border-strong);
  box-sizing: border-box;
}

.plant-picker {
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  color: var(--ga-text);
  background: var(--ga-bg-elevated);
  border-radius: var(--ga-radius-sm);
  border: 1rpx solid var(--ga-border-strong);
}

.plant-inline-actions {
  margin-top: 16rpx;
}

.plant-link-btn {
  display: inline-flex;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ga-brand-mid);
  padding: 8rpx 0;
}

.plant-soil-records {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--ga-border);
}

.plant-soil-records__title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--ga-text-muted);
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.plant-soil-records__row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(42, 77, 58, 0.08);
}

.plant-soil-records__row:last-child {
  border-bottom: none;
}

.plant-soil-records__meta {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ga-text);
  line-height: 1.4;
}

.plant-soil-records__tip {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--ga-text-secondary);
  line-height: 1.45;
}

.plant-knowledge {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: var(--ga-brand);
  background: var(--ga-brand-soft);
  border-radius: var(--ga-radius-sm);
  border: 1rpx solid rgba(42, 77, 58, 0.12);
}

.plant-submit-wrap {
  margin-top: 48rpx;
  margin-bottom: 24rpx;
}

.plant-submit {
  width: 100%;
  text-align: center;
  padding: 28rpx 24rpx;
  border-radius: var(--ga-radius-md);
  font-size: 30rpx;
  font-weight: 700;
  color: #f4faf6;
  background: linear-gradient(135deg, var(--ga-brand), var(--ga-brand-mid));
  box-shadow: var(--ga-shadow);
}
