.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.field {
  margin-bottom: 32rpx;
}

.field.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.field.row .field-label {
  margin-bottom: 0;
}

.field-input {
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.picker-value {
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333;
}

.submit {
  margin-top: 48rpx;
}
