.plant-plan-hero {
  margin-bottom: var(--ga-space-lg);
}

.plant-plan-soil {
  padding: 24rpx 28rpx;
  margin-bottom: var(--ga-space);
}

.plant-plan-soil__kicker {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--ga-brand-mid);
  text-transform: uppercase;
}

.plant-plan-soil__plant {
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ga-text);
  line-height: 1.35;
}

.plant-plan-soil__title {
  display: block;
  margin-top: 18rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ga-text-secondary);
}

.plant-plan-soil__line {
  display: block;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: var(--ga-text);
  line-height: 1.45;
  border-bottom: 1rpx solid rgba(42, 77, 58, 0.08);
}

.plant-plan-soil__line:last-of-type {
  border-bottom: none;
}

.plant-plan-soil__hint {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--ga-text-muted);
}

.plant-plan-actions {
  padding: 20rpx 24rpx;
  margin-bottom: var(--ga-space);
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.plant-plan-refresh {
  display: inline-flex;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ga-brand);
  border: 1rpx solid var(--ga-border-strong);
  text-decoration: none;
}
.plant-plan-refresh--secondary {
  background: var(--ga-brand);
  color: #fafbf9;
  border-color: var(--ga-brand);
}

.plant-plan-muted,
.plant-plan-empty {
  padding: 28rpx;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
}

.plant-plan-row {
  padding: 24rpx 28rpx;
  margin-bottom: var(--ga-space);
}

.plant-plan-row__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.plant-plan-type {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ga-text);
}

.plant-plan-status {
  font-size: 24rpx;
  color: var(--ga-text-muted);
}

.plant-plan-due {
  font-size: 24rpx;
  color: var(--ga-text-secondary);
  font-variant-numeric: tabular-nums;
}
