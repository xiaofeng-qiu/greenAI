.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.picker-value {
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.save {
  margin-top: 24rpx;
}

.section-title {
  margin-top: 40rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.mono {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-top: 8rpx;
}

.weather-line {
  font-size: 26rpx;
  color: #555;
  margin: 16rpx 0;
  line-height: 1.5;
}

.forecast-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}

.forecast-row {
  display: block;
  font-size: 26rpx;
  color: #444;
  line-height: 1.55;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.forecast-hint {
  font-size: 24rpx;
  color: #1565c0;
  background: #e3f2fd;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  line-height: 1.45;
  margin-bottom: 8rpx;
}

.row-btns {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.row-btns button {
  margin: 0;
}
