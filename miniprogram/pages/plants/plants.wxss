.plants-hero {
  margin-bottom: var(--ga-space-lg);
}

.plants-actions {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
  padding: 20rpx;
  margin-bottom: var(--ga-space-lg);
}

.plants-actions__primary {
  flex: 1;
  text-align: center;
  padding: 22rpx 24rpx;
  border-radius: var(--ga-radius-sm);
  font-size: 28rpx;
  font-weight: 700;
  color: #f4faf6;
  background: linear-gradient(135deg, var(--ga-brand), var(--ga-brand-mid));
}

.plants-actions__ghost {
  padding: 22rpx 28rpx;
  border-radius: var(--ga-radius-sm);
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ga-text-secondary);
  border: 1rpx solid var(--ga-border-strong);
  background: var(--ga-bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
}

.plants-empty {
  padding: 40rpx 32rpx;
  text-align: center;
  margin-bottom: var(--ga-space-lg);
}

.plants-empty__title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ga-text);
  margin-bottom: 12rpx;
}

.plants-empty__hint {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  line-height: 1.55;
}

.plants-card {
  padding: 28rpx;
  margin-bottom: var(--ga-space);
}

.plants-card__main {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.plants-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: var(--ga-brand-soft);
  color: var(--ga-brand);
  font-size: 36rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plants-card__body {
  flex: 1;
  min-width: 0;
}

.plants-card__name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ga-text);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plants-card__species {
  display: block;
  font-size: 26rpx;
  color: var(--ga-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plants-card__actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.plants-pill {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.plants-pill--outline {
  border: 1rpx solid var(--ga-border-strong);
  color: var(--ga-brand);
  background: var(--ga-bg-elevated);
}

.plants-pill--danger {
  background: var(--ga-danger-soft);
  color: var(--ga-danger);
}
