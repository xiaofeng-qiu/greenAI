.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.toolbar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn {
  margin: 0;
}

.empty {
  color: #888;
  font-size: 28rpx;
  text-align: center;
  padding: 48rpx 0;
}

.card {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.row.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.row.sub {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
}
