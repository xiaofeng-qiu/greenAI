.page {
  padding: 24rpx;
  box-sizing: border-box;
}

.toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn {
  margin: 0;
}

.empty {
  color: #888;
  font-size: 28rpx;
  padding: 48rpx 0;
  text-align: center;
}

.task-card {
  background: #f7f7f7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.task-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.task-row:last-child {
  margin-bottom: 0;
}

.label {
  color: #666;
  font-size: 26rpx;
}

.value {
  font-size: 28rpx;
  max-width: 70%;
  text-align: right;
}
