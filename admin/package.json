{
  "name": "greenai-admin",
  "private": true,
  "type": "module",
  "scripts": {
    "prisma:generate": "prisma generate --schema ../backend/prisma/schema.prisma",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "dev": "npm run prisma:generate && tsx watch src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
