generator client {

  provider = "prisma-client-js"

}

/// 供仓库根目录 `admin/` 运维服务使用；输出在 `backend/generated/` 以便 Docker 仅构建 API 镜像时路径有效。
generator admin_client {

  provider = "prisma-client-js"

  output   = "../generated/admin-client"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



enum WaterPreference {

  low

  medium

  high

}



enum LightLevel {

  low

  medium

  high

}



enum SoilMoistureHint {

  very_wet

  wet

  moderate

  dry

  very_dry

}



/// 盆土肥力视觉粗分（LLM），与湿度独立

enum SoilFertilityHint {

  unknown

  depleted

  adequate

  rich

}



/// 窗台/主要采光朝向（用户自报）

enum WindowAspect {

  unknown

  north

  south

  east

  west

}



enum CareTaskType {

  water

  fertilize

  repot

  inspect

}



enum CareTaskStatus {

  pending

  completed

  skipped

}



model User {

  id        String   @id @default(cuid())

  openid    String   @unique

  timezone  String   @default("Asia/Shanghai")

  latitude  Float?

  longitude Float?

  /// 逆地理可读标签（如「省 · 市」），保存定位后由服务端填充

  locationLabel String?

  /// 是否长期开空调（偏干环境，略缩短浇水间隔）

  airConditioning Boolean @default(false)

  /// 主要窗台/摆放朝向

  windowAspect    WindowAspect @default(unknown)

  createdAt DateTime @default(now())

  plants    Plant[]

  grants    SubscribeGrant[]

  devices   Device[]

  /// 小程序生成的设备绑定码（固件 claim 后写入 userId）

  deviceBindingCodes DeviceBindingCode[]

}



/// 一次性设备绑定码：用户在小程序生成，在设备配网页输入，联网后固件 POST claim 换 userId

model DeviceBindingCode {

  id        String    @id @default(cuid())

  userId    String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String    @unique

  expiresAt DateTime

  usedAt    DateTime?

  createdAt DateTime  @default(now())



  @@index([userId])

  @@index([expiresAt])

}



model Plant {

  id              String          @id @default(cuid())

  userId          String

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  nickname        String

  speciesLabel    String

  /// 识别或手填：科属（如「天南星科」）

  taxonFamily     String?

  /// 养护难度自评或识别推断：新手 / 进阶 / 专家

  careDifficulty  String?

  waterPreference WaterPreference

  indoor          Boolean

  heating         Boolean

  lightLevel      LightLevel

  /// User self-report soil dryness; nudges watering interval in the care engine.

  soilMoistureHint SoilMoistureHint?

  /// 参考每次浇水量（ml），计划书「浇水量」占位

  waterAmountMl    Int?

  /// 常用肥料类型说明（如「观叶植物液肥」）

  fertilizerType   String?

  /// 个性化注意事项（用户或运营文案）

  careTips           String?

  /// 连续跳过浇水次数，用于轻量拉长间隔

  waterSkipStreak    Int      @default(0)

  createdAt       DateTime        @default(now())

  updatedAt       DateTime        @updatedAt

  carePlan        CarePlan?

  tasks           CareTask[]

  soilRecords     SoilRecord[]

  devices         Device[]



  @@index([userId])

}



/// 第三方/自研环境传感器；每个设备隶属一个用户，可选绑定到某株植物

model Device {

  id          String          @id @default(cuid())

  userId      String

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 设备物理标识（厂商序列号或 MAC），与 userId 联合唯一

  hardwareId  String

  /// 设备显示名（用户自定义，可空）

  label       String?

  /// 可选：绑定到具体植物；为空表示房间/位置级测量

  plantId     String?

  plant       Plant?          @relation(fields: [plantId], references: [id], onDelete: SetNull)

  createdAt   DateTime        @default(now())

  /// 最近一次成功上报时刻（每次 ingest 刷新）

  lastSeenAt  DateTime?

  readings    DeviceReading[]

  ingestLogs  DeviceIngestLog[]



  @@unique([userId, hardwareId])

  @@index([userId])

  @@index([plantId])

}



/// 设备一次采样读数；服务端按 (deviceId, measuredAt) 去重

model DeviceReading {

  id          String   @id @default(cuid())

  deviceId    String

  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  /// 环境温度 ℃；缺失字段允许为空（不同设备覆盖不同维度）

  tempC         Float?

  /// 土壤湿度（0..100）——探针或电容传感器读数

  soilMoisture  Float?

  /// 土壤 pH（0..14）——pH 探针读数

  phLevel       Float?

  /// 光照 lx

  lux           Float?

  /// 设备上报的测量时刻（设备时钟）

  measuredAt  DateTime

  /// 服务端入库时刻

  createdAt   DateTime @default(now())



  @@unique([deviceId, measuredAt])

  @@index([deviceId, measuredAt])

}



/// 固件经 HMAC 上报的运行/诊断日志（与传感器读数 ingest 共用密钥与鉴权方式）

model DeviceIngestLog {

  id         String    @id @default(cuid())

  deviceId   String

  device     Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  level      String    @default("info")

  message    String

  occurredAt DateTime?

  meta       Json?

  createdAt  DateTime  @default(now())



  @@index([deviceId, createdAt])

}



model SoilRecord {

  id                 String            @id @default(cuid())

  plantId            String

  plant              Plant             @relation(fields: [plantId], references: [id], onDelete: Cascade)

  soilMoistureHint   SoilMoistureHint

  soilFertilityHint  SoilFertilityHint @default(unknown)

  rationale          String?

  wateringTip        String?

  /// 模型置信度 0..1（若模型未给则为空）

  confidence         Float?

  createdAt          DateTime          @default(now())



  @@index([plantId, createdAt])

}



model CarePlan {

  id            String   @id @default(cuid())

  plantId       String   @unique

  plant         Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)

  baseIntervalDays Int

  horizonDays      Int   @default(14)

  updatedAt     DateTime @updatedAt

}



model CareTask {

  id            String         @id @default(cuid())

  plantId       String

  plant         Plant          @relation(fields: [plantId], references: [id], onDelete: Cascade)

  type          CareTaskType

  dueDate       DateTime

  status        CareTaskStatus @default(pending)

  /// Set when status becomes `completed` (for funnel / ops metrics).

  completedAt   DateTime?

  notifySentAt  DateTime?

  /// After a failed subscribe send, cron skips this task until this time (exponential backoff).

  notifyNextAttemptAt DateTime?

  notifyFailCount Int          @default(0)

  lastError     String?

  createdAt     DateTime       @default(now())

  notifications NotificationLog[]



  @@index([plantId, dueDate])

  @@index([status, dueDate])

  @@index([completedAt])

}



model SubscribeGrant {

  id          String   @id @default(cuid())

  userId      String

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateId  String

  quota       Int      @default(0)

  updatedAt   DateTime @updatedAt



  @@unique([userId, templateId])

}



model NotificationLog {

  id        String   @id @default(cuid())

  taskId    String

  task      CareTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  templateId String

  errcode   Int?

  errmsg    String?

  createdAt DateTime @default(now())



  @@index([taskId])

}



enum SpeciesProfileSource {

  llm

  manual

}



/// 自建品种养护档案：先按 nameKey 命中，未命中可由 LLM 推断并落库

model SpeciesProfile {

  id             String               @id @default(cuid())

  /// 归一化检索键（trim + Unicode NFKC + 小写）

  nameKey        String               @unique

  /// 与识别结果一致的主展示名

  displayName    String

  taxonFamily    String?

  careDifficulty String?

  careSummary    String?

  /// 偏好土壤 pH 下限（0..14）；通常来源于百度百科描述抽取或 LLM 推断

  phPreferredMin Float?

  /// 偏好土壤 pH 上限（0..14）

  phPreferredMax Float?

  source         SpeciesProfileSource   @default(llm)

  createdAt      DateTime               @default(now())

  updatedAt      DateTime               @updatedAt

  aliases        SpeciesAlias[]

}



enum KnowledgeArticleLayer {

  species_guide

  pest_disease

  environment

}



enum KnowledgeArticleStatus {

  draft

  published

}



/// 可读词条（L1 图文 / L2 病虫害 / L3 环境语境）

model KnowledgeArticle {

  id                  String                   @id @default(cuid())

  /// 与历史小程序 id 对齐，如 epipremnum

  slug                String                   @unique

  title               String

  summary             String                   @default("")

  body                String                   @default("")

  layer               KnowledgeArticleLayer    @default(species_guide)

  status              KnowledgeArticleStatus   @default(draft)

  locale              String                   @default("zh")

  coverTone           Int                      @default(0)

  sections            Json?

  /// 与 diagnoseEngine 症状 id 对齐，用于延伸阅读召回

  symptomIds          String[]                 @default([])

  /// 归一化品种检索键（与 SpeciesProfile.nameKey 同规则），用于品种→图文关联

  speciesNameKeys     String[]                 @default([])

  disclaimerVersion   String?

  publishedAt         DateTime?

  deletedAt           DateTime?

  createdAt           DateTime                 @default(now())

  updatedAt           DateTime                 @updatedAt



  @@index([status, deletedAt])

}



/// L1 品种俗名/别名检索（displayName 以外）

model SpeciesAlias {

  id               String         @id @default(cuid())

  speciesProfileId String

  speciesProfile   SpeciesProfile @relation(fields: [speciesProfileId], references: [id], onDelete: Cascade)

  alias            String

  locale           String         @default("zh")

  createdAt        DateTime       @default(now())



  @@unique([speciesProfileId, alias, locale])

  @@index([alias])

}

